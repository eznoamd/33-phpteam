# ─────────────────────────────────────────────────────────────
#  Arquivo de variáveis de ambiente
#  Copie este arquivo para .env e preencha com seus valores:
#    cp .env.exemplo .env
#
#  NUNCA suba o arquivo .env para o Git!
#  (ele já está no .gitignore)
# ─────────────────────────────────────────────────────────────

# Chave secreta para assinar os tokens JWT
# Gere uma chave forte com: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=sua-chave-secreta-aqui

# Algoritmo do JWT (não precisa mudar)
ALGORITHM=HS256

# Tempo de expiração do token em minutos (60 = 1 hora)
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── IA (Gemini) ──────────────────────────────────────────────
# Obtenha sua chave em: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=chave-de-exemplo-aqui

# Modelo a usar (gemini-1.5-flash é o mais rápido e gratuito)
GEMINI_MODEL=gemini-2.5-flash
